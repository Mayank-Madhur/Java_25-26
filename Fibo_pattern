import java.util.*;
public class Fibo_pattern {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc = new Scanner(System.in);
		int row = sc.nextInt();
		int a = 0, b = 1; // starting Fibonacci numbers
		int i = 1;
		while (i <= row) {
			int j = 1;

			while (j <= i) {
				System.out.print(a + " ");
				int next = a + b;
				a = b;
				b = next;
				j++;
			}

			System.out.println();
			i++;
		}
	}
}
