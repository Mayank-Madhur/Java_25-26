import java.util.*;
public class Pascal_Triangle {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		pascal(n);
	}
	public static void pascal(int n) {
		int row = 0;
		int star = 1;
		while (row <= n) {
			// space
			int i = 0;
			int ncr = 1 ;
			while (i < star) {
				System.out.print(ncr + " ");
				ncr = ((row-i)*ncr)/(i+1);
				i++;
			}  
			System.out.println();
			row++;
			star++;
		}
	}
}

