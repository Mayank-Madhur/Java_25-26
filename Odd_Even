import java.util.*;
public class Odd_Even {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		System.out.println("Even");	
		for(int i=1;n>=i;i++) {
		if(i%2==0)	{
			System.out.println(i);
		}	
		}
		System.out.println("Odd");	
		for(int i=1;i<=n;i++) { 
		if(i%2!=0) {
			System.out.println(i);
		}
		}
	}
}
