import java.util.*;
public class Star_Hollow_Rectangle {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc = new Scanner(System.in);
		int m = sc.nextInt();
		int n = sc.nextInt();
		for(int i = 1; i <= m ; i++) {
			for(int j = 1; j <= n; j++) {
				if(i==1 || i==m || j==1 || j==n) 
					System.out.print("* ");
				else
			System.out.print("  ");
		}
		System.out.println();
	}
		
	}

}
